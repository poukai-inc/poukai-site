---
/**
 * /principles — Trust-closer: ten operating principles that define how pouk.ai works.
 *
 * IA per meta/specs/pages/principles.md sections 4 and 8.
 * Content: intro, ten principles, conclusion from src/content/principles.json.
 *
 * Decisions honoured:
 *   D-09 — page heading "Principles" (not "Operating Principles")
 *   D-10 — intro + conclusion in Instrument Serif italic; principles in sans
 *
 * Anchor IDs per spec: #ownership, #integrity, #reliability, #systems-thinking,
 * #intellectual-curiosity, #obsession, #range, #momentum, #willingness-to-fail,
 * #good-nature
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import { Hero, Principle } from "@poukai-inc/ui";
// principles.json is a single-object file; imported directly (no collection needed
// since no other page reuses it — per spec section 6 deferral rule).
// Build-time Zod validation per R-074 (HARD): schema lives at
// src/content/_schemas/principles.ts; parse failures fail the build.
import principlesRaw from "../content/principles.json";
import { principlesSchema } from "../content/_schemas/principles";
// Page-level copy (meta, hero, end-CTA, JSON-LD) sourced from JSON per R-076
// HARD; intro/conclusion/principles body content stays in principles.json.
import principlesPageRaw from "../content/principles-page.json";
import { principlesPageSchema } from "../content/_schemas/principles-page";

const { intro, conclusion, principles } = principlesSchema.parse(principlesRaw);
const { meta, hero, endCta, jsonLd } = principlesPageSchema.parse(principlesPageRaw);
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  jsonLd={jsonLd}
  currentRoute="/principles"
>
  <div class="site-page">
    <!-- 1. Hero — page h1: "Principles" per D-09 -->
    <Hero
      title={hero.title}
      lede={hero.lede}
    />

    <!-- 2. Introduction — Instrument Serif italic per D-10 -->
    <div class="principles-bookend">
      <p>{intro}</p>
    </div>

    <!-- 3. Ten Principle molecules — sans per D-10 -->
    <!-- sr-only h2 bridges h1 → h3 (Principle) to satisfy axe heading-order (R-026). -->
    <h2 class="visually-hidden">The ten principles</h2>
    <div class="principles-list">
      {principles.map((p) => (
        <div id={p.anchor}>
          <Principle numeral={p.numeral} title={p.title}>
            <p>{p.body}</p>
          </Principle>
        </div>
      ))}
    </div>

    <!-- 4. Conclusion — Instrument Serif italic per D-10 -->
    <div class="principles-bookend">
      <p>{conclusion}</p>
    </div>

    <!-- 5. End CTA — single muted line per spec IA item 6 -->
    <div class="end-cta">
      <p>
        {endCta.lead}{" "}
        <a href={endCta.href}>{endCta.email}</a>
      </p>
    </div>
  </div>
</BaseLayout>
