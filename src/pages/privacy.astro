---
/**
 * /privacy — Privacy Policy for the cal.pouk.ai scheduling app.
 *
 * Google OAuth verification asset (#122): publicly reachable, no login wall,
 * on the pouk.ai authorized domain. Names the Google user data accessed,
 * states use/storage/retention, declares Google API Services User Data Policy
 * + Limited Use compliance (with links), and describes data deletion.
 *
 * Copy: src/content/privacy.json (R-076). Validated: src/content/_schemas/legal.ts (R-074).
 * Utility page — no PM spec / composition recipe by design.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import LegalArticle from "../components/LegalArticle.astro";
import { legalPageSchema } from "../content/_schemas/legal";
import privacyRaw from "../content/privacy.json";

const page = legalPageSchema.parse(privacyRaw);
const { meta } = page;
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  currentRoute="/privacy"
>
  <div class="site-page">
    <LegalArticle page={page} />
  </div>
</BaseLayout>
