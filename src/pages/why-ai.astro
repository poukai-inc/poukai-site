---
/**
 * /why-ai — Thesis page: the AI deployment gap and five failure modes.
 *
 * All copy sourced from src/content/why-ai.json (R-076 HARD) and validated at
 * build time via src/content/_schemas/why-ai.ts (R-074 HARD).
 * Failure-mode cards continue to source from src/content/failure-modes.json
 * via the existing content collection (unchanged).
 *
 * Decisions honoured:
 *   D-01 — footnote-style superscript citations → References block
 *   D-02 — sticky right-rail TOC on desktop ≥ 1024px, CSS-only
 *   D-03 — "Last reviewed" footer
 *   D-04 — discovery questions as inline italic <blockquote>
 *   D-05 — opening + quartile stats render via DS <Stat> molecule
 *   OMC-V1/V4/V5/V6/V7 — prospect-audience rewrite, em-dash titles, "AI systems"
 *     canonical noun, canonical H1 phrasing (ratified 2026-05-19).
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Hero, FailureMode, Stat } from "@poukai-inc/ui";
import whyAiRaw from "../content/why-ai.json";
import { whyAiSchema } from "../content/_schemas/why-ai";

// file() loader returns one CollectionEntry per array item; .data holds the item.
const failureModeEntries = await getCollection("failure-modes");
const sortedModes = failureModeEntries
  .map((e) => e.data)
  .sort((a, b) => a.index - b.index);

const whyAi = whyAiSchema.parse(whyAiRaw);
const {
  meta,
  hero,
  openingArgument,
  pivot,
  failureModesIntro,
  leaders,
  whereWorks,
  endCta,
  references,
  referencesNote,
  lastReviewed,
  jsonLd,
} = whyAi;

const superscriptGlyphs = ["¹", "²", "³", "⁴"];
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  jsonLd={jsonLd}
  currentRoute="/why-ai"
>
  <div class="site-page">
    <Hero title={hero.title} lede={hero.lede} />

    <div class="why-ai-layout">
      <div class="why-ai-main">

        <!-- 2. Opening argument with headline stats -->
        <section aria-label="The deployment gap">
          <p>
            {openingArgument.intro}
            {openingArgument.stats.map((stat, i) => (
              <>
                <strong>{stat.highlight}</strong><sup class="footnote-ref"><a href={`#ref-${stat.citation}`} id={`cite-${stat.citation}`}>{superscriptGlyphs[i]}</a></sup>
                {openingArgument.connectors[i]}
              </>
            ))}
          </p>

          <div class="stats-row" role="list" aria-label="Headline statistics">
            {openingArgument.statsRow.map((stat) => (
              <div role="listitem">
                <Stat value={stat.value} caption={stat.caption} source={stat.source} size="lg" />
              </div>
            ))}
          </div>

          <p>{pivot}</p>
        </section>

        <!-- 3. Section heading — five failure modes -->
        <h2>{failureModesIntro.heading}</h2>
        <p>{failureModesIntro.paragraph}</p>

        <!-- 4. Five FailureMode molecules (data from collection) -->
        <div class="failure-modes-section">
          {sortedModes.map((mode) => (
            <section id={mode.anchor} aria-labelledby={`fm-title-${mode.index}`}>
              <FailureMode index={mode.index} title={mode.title}>
                {mode.stats.length > 0 && (
                  <div class="stats-row" role="list" aria-label={`Statistics for failure mode ${mode.index}`}>
                    {mode.stats.map((stat) => (
                      <div role="listitem">
                        <Stat value={stat.value} caption={stat.caption} source={stat.source} size="lg" />
                      </div>
                    ))}
                  </div>
                )}
                <p>{mode.body}</p>
              </FailureMode>
            </section>
          ))}
        </div>

        <!-- 5. What the leaders do differently -->
        <h2>{leaders.heading}</h2>
        <p>{leaders.intro}</p>
        <ul class="leaders-list">
          {leaders.items.map((item) => (
            <li><strong>{item.title}</strong> — {item.body}</li>
          ))}
        </ul>

        <p>{leaders.outro}</p>

        <div class="quartile-stats" role="list" aria-label="Top-quartile AI deployment statistics">
          {leaders.stats.map((stat) => (
            <div role="listitem">
              <Stat value={stat.value} caption={stat.caption} size="lg" />
            </div>
          ))}
        </div>

        <!-- 6. Where pouk.ai works (prospect-aimed per OMC-V1) -->
        <h2>{whereWorks.heading}</h2>
        <p>{whereWorks.body}</p>
        <p>{whereWorks.discoveryIntro}</p>

        <!-- 7. Discovery questions — inline italic blockquote per D-04 -->
        <blockquote class="discovery-questions" cite="https://pouk.ai/why-ai">
          <ol>
            {whereWorks.questions.map((q) => (
              <li><em>{q}</em></li>
            ))}
          </ol>
        </blockquote>

        <p>{whereWorks.closing}</p>

        <!-- 8. End CTA -->
        <div class="end-cta">
          <p>
            {endCta.primary.lead}{" "}
            <a href={endCta.primary.href}>{endCta.primary.email}</a>
          </p>
          <p>
            {endCta.secondary.lead}{" "}
            <a href={endCta.secondary.anchor.href}>{endCta.secondary.anchor.text}</a>
          </p>
        </div>

        <!-- 9. References — per D-01, footnote-style round-trip -->
        <section class="references" aria-label="References">
          <h2>References</h2>
          <ol>
            {references.map((ref) => (
              <li id={`ref-${ref.index}`}>
                <a href={ref.url} rel="noopener">{ref.title}</a> — {ref.source}
                <a href={`#cite-${ref.index}`} aria-label={`Back to citation ${ref.index}`}>↩</a>
              </li>
            ))}
          </ol>
          <p><em>{referencesNote}</em></p>
        </section>

        <!-- 10. Last reviewed footer per D-03 -->
        <p class="last-reviewed">
          Last reviewed: {lastReviewed.date}. {lastReviewed.lead}{" "}
          <a href={lastReviewed.href}>{lastReviewed.email}</a> {lastReviewed.suffix}
        </p>

      </div>

      <!-- Sticky right-rail TOC — desktop only, CSS-only, no JS per D-02 -->
      <nav class="why-ai-toc" aria-label="Page sections">
        <p class="why-ai-toc-label">Failure modes</p>
        <ol>
          {sortedModes.map((mode) => (
            <li><a href={`#${mode.anchor}`}>{mode.index}. {mode.title}</a></li>
          ))}
        </ol>
      </nav>
    </div>
  </div>
</BaseLayout>
