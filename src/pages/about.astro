---
/**
 * /about — v2.1. Portrait band + brand-voice body. All copy sourced from
 * src/content/about.json (R-076 HARD — content JSON is the only place copy
 * lives) and validated at build time via src/content/_schemas/about.ts (R-074
 * HARD).
 *
 * Composition recipe: meta/compositions/pages/about.md v2 (Approved 2026-05-18).
 * PM spec: meta/specs/pages/about.md v2.1 (Approved 2026-05-18 evening).
 * Content: meta/content/drafts/pages/about.md v2.1.
 *
 * Page structure (4 units, post-v2.1 operator-line retirement):
 *   Unit 1 — <SiteShell> header chrome (via BaseLayout + ShellWrapper)
 *   Unit 2 — <AboutBand> — Hero band (display statement + portrait). The
 *             page's <h1> lives inside <Hero>'s title slot.
 *   Unit 3 — Story body (2 paragraphs, brand-voice declarative)
 *   Unit 4 — Pouākai section (<h2> + verbatim body)
 *   Unit 5 — End CTA (muted line, mailto link) + <SiteShell> footer chrome
 *
 * v2.1 retired: orange band, sole-operator framing, operator-line block.
 * Founder name now surfaces only in portrait caption + alt + Person JSON-LD.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import { AboutBand } from "../components/AboutBand";
import aboutRaw from "../content/about.json";
import { aboutSchema } from "../content/_schemas/about";

const about = aboutSchema.parse(aboutRaw);
const { meta, band, story, poukai, endCta, jsonLd } = about;
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  jsonLd={jsonLd}
  currentRoute="/about"
  portraitPreload={band.portrait.src}
>
  <AboutBand
    portraitSrc={band.portrait.src}
    portraitAlt={band.portrait.alt}
    portraitAspect={band.portrait.aspect}
    portraitWidth={band.portrait.width}
    portraitCaption={band.portrait.caption}
    displayStatement={band.displayStatement}
    supportingLine={band.supportingLine}
  />

  <div class="site-page about-tail">
    <section class="about-story" aria-label="About pouk.ai">
      <div class="about-story__body">
        {story.paragraphs.map((p) => <p>{p}</p>)}
      </div>
    </section>

    <section class="about-poukai" aria-labelledby={poukai.anchor}>
      <h2 id={poukai.anchor} class="about-poukai__heading">{poukai.heading}</h2>
      <p class="about-poukai__body">{poukai.body}</p>
    </section>

    <div class="end-cta">
      <p>
        {endCta.text}{" "}
        <a href={endCta.href}>{endCta.email}</a>.
      </p>
    </div>
  </div>
</BaseLayout>
