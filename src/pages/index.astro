---
/**
 * / — Homepage. All copy sourced from src/content/home.json (R-076 HARD) and
 * validated at build time via src/content/_schemas/home.ts (R-074 HARD).
 *
 * Page structure:
 *   - SiteShell (via BaseLayout + ShellWrapper)
 *   - HomeHero (status + title + lede + CTA inside <Hero size="intimate"
 *     entrance="stagger">)
 *
 * The Hero's display posture is editorial-doorway (entrance="stagger" per
 * meta/decisions/2026-05-19-hero-stagger-scope.md). No body sections beyond
 * the Hero — spec §4 forbids additional sections ("adding sections is a
 * brand violation").
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import { HomeHero } from "../components/HomeHero";
import homeRaw from "../content/home.json";
import { homeSchema } from "../content/_schemas/home";

const home = homeSchema.parse(homeRaw);
const { meta, hero, jsonLd } = home;
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={meta.canonical}
  jsonLd={jsonLd}
  currentRoute="/"
>
  <div class="site-page">
    <HomeHero
      status={hero.status}
      titleBefore={hero.title.before}
      titleEm={hero.title.em}
      titleAfter={hero.title.after}
      ledeSentence1={hero.lede.sentence1}
      ledeSentence2={hero.lede.sentence2}
      ledeAnchorText={hero.lede.anchor.text}
      ledeAnchorHref={hero.lede.anchor.href}
      ctaLabel={hero.cta.label}
      ctaHref={hero.cta.href}
    />
  </div>
</BaseLayout>
