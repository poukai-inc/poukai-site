---
/**
 * BaseLayout.astro
 *
 * HTML shell for all Astro-rendered pages. Owns:
 *   - <html> / <head> (meta, canonical, OG, Twitter, JSON-LD, font preload)
 *   - @poukai-inc/ui/tokens.css import (design tokens)
 *   - @poukai-inc/ui/styles.css import (component styles — new in DS 2.0.0)
 *   - site.css import
 *   - Matomo env-var-gated tracker tag (emits nothing when unset)
 *   - (Bugsink error-reporting SDK intentionally not wired — see frontmatter
 *     note; removed 2026-05-31 per #90, re-add self-hosted once O-012 lands)
 *   - SiteShell organism wrapping <slot />
 *
 * Does NOT port the static /index.html — that lives verbatim in public/.
 *
 * DS 2.0.0 split runtime CSS into two files: `tokens.css` (design tokens)
 * and `styles.css` (component visual styles). Prior versions inlined the
 * component CSS via Vite's JS-side `import "./Foo.css"` so a single
 * `tokens.css` import was enough; 2.0.0 ships pre-extracted CSS and
 * requires consumers to import both. Without `styles.css`, organisms like
 * <SiteShell> render unstyled.
 */

import "@poukai-inc/ui/tokens.css";
import "@poukai-inc/ui/styles.css";
import "../styles/site.css";
import { ClientRouter } from "astro:transitions";
import { ShellWrapper } from "../components/ShellWrapper";
// Vercel Web Analytics — basic-tier signal.
//
// The SDK injects `<script src="/_vercel/insights/script.js">` unconditionally
// when the component renders. That URL only exists on Vercel deployments, so
// emitting the tag in a non-Vercel build (e.g. CI's `pnpm preview`) produces
// a 404 → "Browser errors logged to the console" → drops Lighthouse
// best-practices from 1.00 to 0.96. Gate the emit on the build-time
// `VERCEL=1` env var that Vercel sets in its build container. Static builds
// produced anywhere else (CI, local `pnpm build`) skip the tag entirely.
//
// Enable collection via the Vercel dashboard (Project → Analytics → Enable).
// Cookieless, no opt-in banner required.
import Analytics from "@vercel/analytics/astro";

const isVercelBuild = process.env.VERCEL === "1";

// Vite resolves these to the same hashed /_astro/*.woff2 URLs that the
// @poukai-inc/ui tokens.css @font-face rules reference at runtime, so the
// preload `<link>` and the CSS request hit one file (no duplicate fetch,
// no font-swap shift). See `meta/decisions/D-XX` (font-preload deduplication).
import geistVariableUrl from "@poukai-inc/ui/fonts/Geist-Variable.woff2?url";
import instrumentSerifRegularUrl from "@poukai-inc/ui/fonts/InstrumentSerif-Regular.woff2?url";

export interface Props {
  /** <title> for this page. */
  title: string;
  /** <meta name="description"> — 70–160 chars. */
  description: string;
  /** Absolute canonical URL for this page. Used for OG url and (unless suppressed) <link rel="canonical">. */
  canonical: string;
  /**
   * JSON-LD structured data object for this page.
   * BaseLayout serialises it into a <script type="application/ld+json">.
   */
  jsonLd?: Record<string, unknown>;
  /** The href of the currently active route — passed to SiteShell for aria-current. */
  currentRoute: string;
  /**
   * Optional path to a page-critical image that should be preloaded for LCP.
   * When set, BaseLayout emits a <link rel="preload" as="image"> in <head>.
   * Used by /about to preload the above-fold portrait asset.
   * Spec: meta/specs/pages/about.md §6.1 (preload strategy — above-the-fold portrait).
   */
  portraitPreload?: string;
  /**
   * Override for <meta name="robots">. Default: "index,follow".
   * /404 passes "noindex,follow" per meta/specs/pages/404.md §6.
   */
  robots?: string;
  /**
   * When true, suppresses <link rel="canonical">. Used by /404, which must
   * not declare a canonical URL (meta/specs/pages/404.md §6 — adding one would
   * either self-reference or deceive the crawler).
   */
  omitCanonicalLink?: boolean;
  /**
   * Optional absolute OG image URL. Used by /writing/[slug] for per-essay OG
   * cards (writing.json.md §4 — falls back to the site /og.png when unset).
   * Must be an absolute https URL; the site default is https://pouk.ai/og.png.
   */
  ogImage?: string;
}

const {
  title,
  description,
  canonical,
  jsonLd,
  currentRoute,
  portraitPreload,
  robots = "index,follow",
  omitCanonicalLink = false,
  ogImage,
} = Astro.props;

const ogImageUrl = ogImage ?? "https://pouk.ai/og.png";
const twitterSite = "@pouk_ai";

/** Primary nav — funnel order per D-13; About added per A4 (spec /about §9).
 * Engagements added 4th per engagements.md §9 (LOCKED order:
 * Why AI · Roles · Engagements · Principles · About). /writing is deliberately
 * NOT in the primary nav (writing.md §9) — footer link + essay cross-links only. */
const navRoutes = [
  { href: "/why-ai",      label: "Why AI" },
  { href: "/roles",       label: "Roles" },
  { href: "/engagements", label: "Engagements" },
  { href: "/principles",  label: "Principles" },
  { href: "/about",       label: "About" },
];

const currentYear = new Date().getFullYear();

// Serialise JSON-LD at build time — safe because content comes from typed props.
const jsonLdString = jsonLd ? JSON.stringify(jsonLd) : null;

// Env-var-gated analytics / error reporting — emit nothing when unset.
// TODO: provide Matomo endpoint (O-011) — set PUBLIC_MATOMO_URL + PUBLIC_MATOMO_SITE_ID in Vercel env
const matomoUrl = import.meta.env.PUBLIC_MATOMO_URL as string | undefined;
const matomoSiteId = import.meta.env.PUBLIC_MATOMO_SITE_ID as string | undefined;
const hasMatomoConfig = Boolean(matomoUrl && matomoSiteId);

// NOTE: Bugsink/Sentry error-reporting client SDK is intentionally NOT wired
// here. The prior implementation inline-imported the SDK from a third-party
// CDN (browser.sentry-cdn.com) — that violated R-011 (third-party logic must
// load from its own same-origin file, not inline) and R-050 (no new
// third-party runtime origin). It was inert (no DSN) and removed 2026-05-31
// (#90). Re-add as a self-hosted, same-origin <script src> per R-061 when
// O-012 picks the deploy shape and a DSN exists.

// Build the Matomo tracker script string at build time (only when configured).
// Env values are embedded via JSON.stringify so they land as properly-quoted,
// escaped JS string literals — a value containing `"` / `</script>` / `;` can't
// break out of the string and execute. set:html does no escaping of its own.
const matomoScript = hasMatomoConfig
  ? `var _paq = window._paq = window._paq || [];
_paq.push(['disableCookies']);
_paq.push(['trackPageView']);
_paq.push(['enableLinkTracking']);
(function() {
  var u = ${JSON.stringify(matomoUrl)};
  _paq.push(['setTrackerUrl', u + 'matomo.php']);
  _paq.push(['setSiteId', ${JSON.stringify(matomoSiteId)}]);
  var d = document, g = d.createElement('script'), s = d.getElementsByTagName('script')[0];
  g.async = true; g.src = u + 'matomo.js'; s.parentNode.insertBefore(g, s);
})();`
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    {/* R-027 exception: <meta> attributes can't reference CSS custom properties, so the literal hex
       is unavoidable here. Keep in sync with --bg-base in @poukai-inc/ui/tokens.css. */}
    <meta name="theme-color" content="#FFFFFF" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {omitCanonicalLink ? null : <link rel="canonical" href={canonical} />}
    <meta name="robots" content={robots} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={twitterSite} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!--
      Font preload — fonts shipped by @poukai-inc/ui and bundled to /_astro/*.woff2.
      Two critical fold faces per R-018: Geist Regular (variable) + Instrument Serif Regular.
      Italic Instrument Serif is non-critical (only used on /principles bookend) and lazy-loads.
      crossorigin is required for font preloads even on same-origin (browser spec).
      Imports use Astro `?url` so the preload `href` matches the @font-face URL CSS requests,
      eliminating the duplicate font fetch + font-swap layout shift seen in the 2026-05-17 LH audit.
    -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={geistVariableUrl}
      crossorigin=""
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={instrumentSerifRegularUrl}
      crossorigin=""
    />

    <!--
      Portrait preload — emitted only when portraitPreload is set (currently /about only).
      Preloads the above-fold portrait asset for LCP. The JPEG is served from public/
      directly; the browser's AVIF/WebP negotiation happens at the <picture> level.
      Spec: meta/specs/pages/about.md §6.1 + composition §6.7 preload strategy.
    -->
    {portraitPreload ? (
      <link
        rel="preload"
        as="image"
        href={portraitPreload}
        type="image/jpeg"
      />
    ) : null}

    <!--
      JSON-LD structured data (serialised in frontmatter; set:html injects verbatim).
      Ternary with null avoids the && short-circuit pattern that esbuild's JSX
      transform misreads as an incomplete ternary expression.
    -->
    {jsonLdString ? <script is:inline type="application/ld+json" set:html={jsonLdString} /> : null}

    <!--
      analytics: matomo
      Loads only when PUBLIC_MATOMO_URL + PUBLIC_MATOMO_SITE_ID are set.
      Cookieless mode at launch (no _pk_* cookies). Deferred — no render blocking.
      TODO: O-011 — decide self-hosted vs. Matomo Cloud before wiring endpoints.
    -->
    {matomoScript ? <script is:inline defer set:html={matomoScript} /> : null}

    <!--
      error-reporting: bugsink — intentionally not wired. See the frontmatter
      note: the prior third-party-CDN inline import violated R-011/R-050 and was
      removed 2026-05-31 (#90). Re-add self-hosted (R-061) once O-012 lands.
    -->

    <!--
      Subtle cross-page view transitions.
      Astro's <ClientRouter /> upgrades navigation to client-side swaps and
      drives the native View Transitions API (Chromium/Safari) with a
      graceful no-animation fallback in Firefox. The default root animation
      is overridden in site.css to a brief opacity-only fade tuned to
      --dur-fast, and disabled under prefers-reduced-motion (R-030).
    -->
    <ClientRouter />
  </head>
  <body>
    <!-- SiteShell renders as static HTML — no hydration directive (R-079). -->
    <ShellWrapper
      currentRoute={currentRoute}
      routes={navRoutes}
      year={currentYear}
    >
      <slot />
    </ShellWrapper>
    {isVercelBuild ? <Analytics /> : null}
  </body>
</html>
